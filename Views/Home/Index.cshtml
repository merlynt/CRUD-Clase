@using System.Security.Claims

@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout1.cshtml";
}

@model IEnumerable<appWeb2.Models.VideoJuego>
<section class="banner text-center text-white">
</section>
<div class="container mt-5">
    <div class="row text-center mb-5">
        <div class="col-md-3 mb-3">
            <div class="dropdown" style="position: relative;">
                <div class="feature-card" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                     style="cursor: pointer; width: 100%; transition: 0.3s;">
                    <i class="fas fa-gamepad"></i>
                    <h5>Categorías</h5>
                    <p>Explora por tipo</p>
                </div>
                <ul class="dropdown-menu shadow border-0 p-2"
                    style="background-color: #002a33; width: 100%; border-radius: 12px; z-index: 1050; margin-top: 5px;">
                    <li>
                        <a class="dropdown-item text-warning fw-bold text-center" asp-action="Index"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffc107';">
                            Ver Todos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
                    @{
                        
                        var categorias = ViewBag.CategoriasDisponibles as List<string>;

                        if (categorias != null)
                        {
                            foreach (var cat in categorias)
                            {
                                <li>
                                    <a class="dropdown-item text-white text-center"
                                       asp-action="categoryFilter"
                                       asp-route-category="@cat"
                                       style="border-radius: 8px; transition: 0.2s;"
                                       onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                                       onmouseout="this.style.backgroundColor='transparent'; this.style.color='white';">
                                        @cat
                                    </a>
                                </li>
                            }
                        }
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <a asp-action="Index" asp-route-sortOrder="ventas" style="text-decoration: none; color: inherit;">
                <div class="feature-card" style="cursor: pointer; width: 100%;">
                    <i class="fas fa-fire"></i>
                    <h5>Más Vendidos</h5>
                    <p>Los más populares</p>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <div class="dropdown" style="position: relative;">
                <div class="feature-card" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer; width: 100%;">
                    <i class="fas fa-star"></i>
                    <h5>Nuevos Juegos</h5>
                    <p>Lo último</p>
                </div>
                <ul class="dropdown-menu shadow border-0 p-2"
                    style="background-color: #002a33; width: 100%; border-radius: 12px; z-index: 1050; margin-top: 5px;">
                    <li>
                        <a class="dropdown-item text-warning fw-bold text-center" asp-action="Index" asp-route-sortOrder="nuevos"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffc107';">
                            Ver Todos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
                    <li>
                        <a class="dropdown-item text-white text-center" asp-action="Novedades" asp-route-ver="top5"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='white';">
                            Ver los más nuevos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
                    
                </ul>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="dropdown" style="position: relative;">
                <div class="feature-card" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer; width: 100%;">
                    <i class="fas fa-tags"></i>
                    <h5>Promociones</h5>
                    <p>Ofertas especiales</p>
                </div>
                <ul class="dropdown-menu shadow border-0 p-2"
                    style="background-color: #002a33; width: 100%; border-radius: 12px; z-index: 1050; margin-top: 5px;">
                    <li>
                        <a class="dropdown-item text-warning fw-bold text-center" asp-action="Index"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffc107';">
                            Ver Todos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>

                    @{
                        var descuentos = new[] { 0.10, 0.20, 0.50};
                        foreach (var des in descuentos)
                        {
                            var porcentajeMostrar = (int)(des * 100);

                            <li>
                                <a class="dropdown-item text-white text-center" asp-action="promociones" asp-route-minDescuento="@des.ToString("0.00")"
                                   style="border-radius: 8px; transition: 0.2s;"
                                   onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                                   onmouseout="this.style.backgroundColor='transparent'; this.style.color='white';">
                                    <span class="fw-bold text-info">@porcentajeMostrar%</span> OFF o más
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

    </div>

    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;"> Videojuegos Disponibles</h2>
    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100">

                    <!-- 🔴 BADGE SUPERIOR -->
                    <div class="badge-top">@juego.clasificacionEdad</div>

                    <!-- ❤️ FAVORITO -->
                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <!-- IMAGEN -->
                    <img src="@juego.imagen"
                         class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">

                        <!-- TÍTULO -->
                        <h5 class="card-title fw-bold">
                            @juego.titulo
                        </h5>


                        <!-- PRECIO -->
                        <h4 class="price mt-2">
                            $@juego.precio
                        </h4>

                        <!-- CATEGORÍA -->
                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted">@juego.categoria</span>
                        </div>

                    </div>
                    <div class="p-3">
                        <div class="paypal-btn-wrapper" data-juego-id="@juego.id" id="paypal-button-container-@juego.id"></div>
                    </div>
                </div>
            </div>
        }
    </div> 
    @if (ViewBag.TotalPaginas > 1)
    {
        <style>
            /* Estilos personalizados para la paginación Gamer */
            .pagination-custom .page-item {
                margin: 0 4px; /* Separación entre los botones */
            }

            .pagination-custom .page-link {
                background-color: #002a33; /* Fondo oscuro de tu diseño */
                color: white;
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 8px !important; /* Bordes redondeados */
                transition: all 0.3s ease;
                font-weight: 500;
            }

                .pagination-custom .page-link:hover {
                    background-color: #001a20; /* Más oscuro al pasar el mouse */
                    color: #ffc107; /* Texto amarillo */
                    border-color: #ffc107;
                    box-shadow: 0 0 8px rgba(255, 193, 7, 0.3); /* Brillo sutil */
                }

            .pagination-custom .page-item.active .page-link {
                background-color: #ffc107; /* Fondo amarillo para la página actual */
                color: #000; /* Texto negro para resaltar */
                border-color: #ffc107;
                font-weight: bold;
            }

            .pagination-custom .page-item.disabled .page-link {
                background-color: rgba(0, 42, 51, 0.4);
                color: #6c757d;
                border-color: transparent;
                cursor: not-allowed;
            }
        </style>

        <div class="d-flex justify-content-center mt-5 mb-5">
            <ul class="pagination pagination-lg shadow-sm pagination-custom">

                <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link px-4" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual - 1)">
                        <i class="fa-solid fa-chevron-left me-1"></i> Anterior
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                {
                    <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
                    <a class="page-link px-4" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual + 1)">
                        Siguiente <i class="fa-solid fa-chevron-right ms-1"></i>
                    </a>
                </li>

            </ul>
        </div>
    }
</div>
@section Scripts {
    <script src="https://www.paypal.com/sdk/js?client-id=AbHZfgDm_PVlYsDXdPl144asu0P3pGPCDuZPmblOsLLJZ4K--87fx1KduQUQVbaEIlrZi2eaDGE_5dGz&currency=USD"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const contenedores = document.querySelectorAll('.paypal-btn-wrapper');

            contenedores.forEach(contenedor => {
                const videoJuegoId = contenedor.getAttribute('data-juego-id');
                const contenedorId = contenedor.id;

                renderizarBotonPaypal(videoJuegoId, contenedorId);
            });

        });

        function renderizarBotonPaypal(videoJuegoId, contenedorId) {
            paypal.Buttons({
                createOrder: async (data, actions) => {
                    try {
                        const response = await fetch('/api/Checkout/create-order', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ videoJuegoId: videoJuegoId })
                        });

                        if (response.status === 401) {
                             alert("Su sesión ha expirado. Por favor, inicie sesión nuevamente.");
                            window.location.href = "/Account/Login";
                            return;
                        }
                
                        if (!response.ok) {
                            const errorText = await response.text();
                            throw new Error(`Error en el servidor (${response.status}): ${errorText}`);
                        }
               
                        const order = await response.json();
                        return order.id;

                    } catch (err) {
                
                        console.error("Fallo crítico en la creación de la orden:", err);
                        alert("No se pudo conectar con el servidor de pagos. Intente más tarde.");
                    }
        },

                onApprove: async (data, actions) => {
                    try{
                        const response = await fetch('/api/Checkout/capture-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            orderId: data.orderID,
                            videoJuegoId: parseInt(videoJuegoId),
                        })
                        });

                        if (response.ok) {
                            alert("¡Compra realizada con éxito!");
                            //window.location.reload();
                        } else {
                            const errorText = await response.text();
                            alert("Fallo la compra: " + errorText);
                            console.error("Detalles del servidor:", errorText);
                        }
                    } catch (err) {
                
                        console.error("Error crítico en onApprove:", err);
                        alert("Ocurrió un error inesperado al procesar tu pago.");
                    }
                    
                },

                onError: (err) => {
                    console.error("Error en PayPal: ", err);
                }
            }).render(`#${contenedorId}`);
        }
    </script>
}