
@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout1.cshtml";
}


@model IEnumerable<appWeb2.Models.VideoJuego>

<div class="container mt-5">
    <div class="row text-center mb-5">

        <div class="col-md-3 mb-3">
            <div class="dropdown" style="position: relative;">
                <div class="feature-card" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                     style="cursor: pointer; width: 100%; transition: 0.3s;">
                    <i class="fas fa-gamepad"></i>
                    <h5>Categorías</h5>
                    <p>Explora por tipo</p>
                </div>
                <ul class="dropdown-menu shadow border-0 p-2"
                    style="background-color: #002a33; width: 100%; border-radius: 12px; z-index: 1050; margin-top: 5px;">
                    <li>
                        <a class="dropdown-item text-warning fw-bold text-center" asp-action="Index"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffc107';">
                            Ver Todos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
                    @{
                        
                        var categorias = ViewBag.CategoriasDisponibles as List<string>;

                        if (categorias != null)
                        {
                            foreach (var cat in categorias)
                            {
                                <li>
                                    <a class="dropdown-item text-white text-center"
                                       asp-action="categoryFilter"
                                       asp-route-category="@cat"
                                       style="border-radius: 8px; transition: 0.2s;"
                                       onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                                       onmouseout="this.style.backgroundColor='transparent'; this.style.color='white';">
                                        @cat
                                    </a>
                                </li>
                            }
                        }
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <a asp-action="Index" asp-route-sortOrder="ventas" style="text-decoration: none; color: inherit;">
                <div class="feature-card" style="cursor: pointer; width: 100%;">
                    <i class="fas fa-fire"></i>
                    <h5>Más Vendidos</h5>
                    <p>Los más populares</p>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <div class="dropdown" style="position: relative;">
                <div class="feature-card" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer; width: 100%;">
                    <i class="fas fa-star"></i>
                    <h5>Nuevos Juegos</h5>
                    <p>Lo último</p>
                </div>
                <ul class="dropdown-menu shadow border-0 p-2"
                    style="background-color: #002a33; width: 100%; border-radius: 12px; z-index: 1050; margin-top: 5px;">
                    <li>
                        <a class="dropdown-item text-warning fw-bold text-center" asp-action="Index" asp-route-sortOrder="nuevos"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffc107';">
                            Ver Todos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
                    <li>
                        <a class="dropdown-item text-white text-center" asp-action="Novedades" asp-route-ver="top5"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='white';">
                            Ver los más nuevos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>
                    
                </ul>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="dropdown" style="position: relative;">
                <div class="feature-card" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer; width: 100%;">
                    <i class="fas fa-tags"></i>
                    <h5>Promociones</h5>
                    <p>Ofertas especiales</p>
                </div>
                <ul class="dropdown-menu shadow border-0 p-2"
                    style="background-color: #002a33; width: 100%; border-radius: 12px; z-index: 1050; margin-top: 5px;">
                    <li>
                        <a class="dropdown-item text-warning fw-bold text-center" asp-action="Index"
                           style="border-radius: 8px; transition: 0.2s;"
                           onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                           onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ffc107';">
                            Ver Todos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.1);"></li>

                    @{
                        var descuentos = new[] { 0.10, 0.20, 0.50};
                        foreach (var des in descuentos)
                        {
                            var porcentajeMostrar = (int)(des * 100);

                            <li>
                                <a class="dropdown-item text-white text-center" asp-action="promociones" asp-route-minDescuento="@des.ToString("0.00")"
                                   style="border-radius: 8px; transition: 0.2s;"
                                   onmouseover="this.style.backgroundColor='#001a20'; this.style.color='#ffc107';"
                                   onmouseout="this.style.backgroundColor='transparent'; this.style.color='white';">
                                    <span class="fw-bold text-info">@porcentajeMostrar%</span> OFF o más
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

    </div>

    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;"> Videojuegos Disponibles</h2>
    <div class="row g-4">
        @foreach (var juego in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card game-card h-100">

                    <!-- 🔴 BADGE SUPERIOR -->
                    <div class="badge-top">@juego.clasificacionEdad</div>

                    <!-- ❤️ FAVORITO -->
                    <div class="favorite">
                        <i class="fa-regular fa-heart"></i>
                    </div>

                    <!-- IMAGEN -->
                    <img src="@juego.imagen"
                         class="card-img-top game-img" />

                    <div class="card-body d-flex flex-column">

                        <!-- TÍTULO -->
                        <h5 class="card-title fw-bold">
                            @juego.titulo
                        </h5>


                        <!-- PRECIO -->
                        <h4 class="price mt-2">
                            $@juego.precio
                        </h4>

                        <!-- CATEGORÍA -->
                        <div class="d-flex align-items-center mt-auto">
                            <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                            <span class="text-muted">@juego.categoria</span>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>