@using System.Text.Json
@using appWeb2.Models
@{
    // Leemos la sesión del usuario como lo tienes en tu admin
    var usuarioJson = Context.Session.GetString("usuario");
    Usuario usuarioLogueado = null;

    if (!string.IsNullOrEmpty(usuarioJson))
    {
        var opciones = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        usuarioLogueado = JsonSerializer.Deserialize<Usuario>(usuarioJson, opciones);
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameStore</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://www.paypal.com/sdk/js?client-id=AbHZfgDm_PVlYsDXdPl144asu0P3pGPCDuZPmblOsLLJZ4K--87fx1KduQUQVbaEIlrZi2eaDGE_5dGz&currency=USD"></script>
</head>

<body class="bg-dark-custom">

    <header>
        <nav class="navbar navbar-expand-lg navbar-custom shadow">
            <div class="container">

                <a class="navbar-brand fw-bold text-warning" asp-controller="Home" asp-action="Index">
                    GameStore
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuNavbar">

                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contacts">contacto</a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">lo nuevo</a>
                        </li>               
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (usuarioLogueado != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light fw-bold" href="#" id="menuUsuario" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-user me-1 text-warning"></i> @usuarioLogueado.nombre
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end dropdown-gamestore shadow-lg" aria-labelledby="menuUsuario">

                                    <li>
                                        <a class="dropdown-item dropdown-item-gaming" asp-controller="Account" asp-action="Gestionar">
                                            <i class="fa-solid fa-user-gear me-2 text-warning"></i> Mi Cuenta
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item dropdown-item-gaming" asp-controller="Account" asp-action="MisCompras">
                                            <i class="fa-solid fa-bag-shopping me-2 text-warning"></i> Mis Compras
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider-gaming"></li>

                                    <li>
                                        <a class="dropdown-item dropdown-item-gaming text-danger-hover" asp-controller="Account" asp-action="Logout">
                                            <i class="fa-solid fa-right-from-bracket me-2 text-danger"></i>
                                            <span class="fw-bold">Cerrar Sesión</span>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    Iniciar Sesión
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-warning ms-2 text-dark fw-bold" asp-controller="Account" asp-action="Register">
                                    Registrarse
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-custom text-center py-3 mt-5 text-white">
        <div class="container">
            &copy; 2026 - GameStore | Todos los derechos reservados
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>