@using System.Text.Json
@using appWeb2.Models
@{
    var usuarioJson = Context.Session.GetString("usuario");
    Usuario usuarioLogueado = null;

    if (!string.IsNullOrEmpty(usuarioJson))
    {
        var opciones = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        usuarioLogueado = JsonSerializer.Deserialize<Usuario>(usuarioJson, opciones);
        
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Administrativo</title>

    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://code.highcharts.com/modules/exporting.js"></script>
    <script src="https://code.highcharts.com/modules/export-data.js"></script>
    <script src="https://code.highcharts.com/modules/accessibility.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.js" crossorigin="anonymous"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #f5f7fb;
        }

        .navbar-custom {
            background: linear-gradient(90deg, #1e3c72, #2a5298);
        }

        .navbar-brand {
            font-weight: bold;
            color: white !important;
        }

        .navbar-custom .nav-link {
            color: #ffffff !important; /* Blanco puro */
            font-weight: 500;
            margin: 0 10px;
            transition: all 0.3s ease;
            opacity: 0.9;
        }

        .user-info {
            color: white;
            font-weight: 500;
        }

        .btn-logout {
            border-radius: 10px;
        }

        .dashboard-container {
            padding: 30px;
        }

        .welcome-box {
            background: white;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .content-card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }

        .table {
            margin-top: 10px;
        }

            .table thead th {
                background-color: #f8f9fa;
                color: #64748b;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                border-top: none;
                padding: 15px;
            }

            .table tbody td {
                padding: 15px;
                vertical-align: middle;
                border-bottom: 1px solid #f1f5f9;
            }

        .status-badge {
            background: #e0e7ff;
            color: #4338ca;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .pagination .page-link {
            border: none;
            margin: 0 3px;
            border-radius: 8px;
            color: #1e3c72;
            font-weight: 500;
        }

        .pagination .page-item.active .page-link {
            background-color: #1e3c72;
            color: white;
        }

        .filter-section {
            display: flex;
            align-items: flex-end;
            gap: 15px;
            flex-wrap: wrap;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-custom px-4 shadow">
        <a class="navbar-brand" asp-controller="Account" asp-action="Dashboard">Administración de sistema</a>

        <button class="navbar-toggler border-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Account" asp-action="Dashboard">
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "VideoJuegos" ? "active" : "")"
                       asp-controller="VideoJuegos" asp-action="Index">
                        Videojuegos
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "DetalleVentas" ? "active" : "")"
                       asp-controller="Account" asp-action="DetalleVentas">
                        Ventas
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Usuario" ? "active" : "")"
                       asp-controller="Usuario" asp-action="Index">
                        Usuarios
                    </a>
                </li>
            </ul>

            <div class="ms-auto d-flex align-items-center gap-3">

                @if (usuarioLogueado != null)
                {
                    <span class="user-info">
                        @usuarioLogueado.nombre
                    </span>

                    <a asp-controller="Account" asp-action="Logout" class="btn btn-light btn-sm btn-logout">
                        Cerrar Sesión
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-sm">
                        Iniciar Sesión
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm ms-2">
                        Registrarse
                    </a>
                }

            </div>
        </div>
    </nav>
    <div class="dashboard-container">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>