@{
	Layout = "~/Views/Shared/_Layout1.cshtml";
	var usuario = Context.Session.GetString("usuario");
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<style >
	.table-custom {
		background-color: #1e293b;
		color: #f8fafc;
		border-collapse: collapse;
		width: 100%;
	}
	.table-custom th,
	.table-custom td {
		background-color: #1e293b;
		color: #f8fafc;
		border-bottom: 1px solid #334155;
		padding: 12px;
	}

	.table-custom th {
		background-color: #334155;
		color: #f8fafc; 
	}

	.table-custom tbody tr:hover td {
		background-color: #2d3e5a;
	}

	.btn-action {
		padding: 6px 10px;
		font-size: 0.85rem;
		border-radius: 6px;
		transition: all 0.2s ease;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 5px;
		border: none;
	}

	.btn-edit {
		background-color: #3b82f6;
		color: white;
	}

		.btn-edit:hover {
			background-color: #2563eb;
			transform: translateY(-2px);
			color: white;
		}

	.btn-details {
		background-color: #64748b;
		color: white;
	}

		.btn-details:hover {
			background-color: #475569;
			transform: translateY(-2px);
			color: white;
		}

	.btn-delete {
		background-color: #ef4444;
		color: white;
	}

		.btn-delete:hover {
			background-color: #dc2626;
			transform: translateY(-2px);
			color: white;
		}

	.actions-container {
		display: flex;
		gap: 8px;
	}
</style>


@model IEnumerable<appWeb2.Models.VideoJuego>
<h2>Lista de Video juegos</h2>
<a asp-action="Create" class="btn btn-primary">Nuevo Juego</a>
<table class="table-custom mt-3">
	<thead>
		<tr>
			<th>Titulo</th>
			<th>Descripcion</th>
			<th>Categoria</th>
			<th>Clasificacion</th>
			<th>Precio</th>
			<th>Imagen</th>
			<th>Fecha de lanzamiento</th>
			<th>Descuento %</th>
			<th>Acciones</th>
		</tr>
	</thead>
	<tbody>
		@foreach(var juego in Model)
		{
			<tr>
				<td><strong>@juego.titulo</strong></td>
				<td>@juego.descripcion</td>
				<td><span class="badge bg-secondary">@juego.categoria</span></td>
				<td>@juego.clasificacionEdad</td>
				<td>$@juego.precio</td>
				<td><img src="@juego.imagen" width="120" /></td>
				<td>@juego.fechaLanzamiento.ToString("dd MMMM yyyy")</td>
				<td>
					@if (juego.porcentajeDescuento > 0)
					{
						<span class="badge rounded-pill bg-success">
							<i class="bi bi-tag-fill"></i> -@juego.porcentajeDescuento%
						</span>
					}
					else
					{
						<span class="text-muted small">Sin oferta</span>
					}
				</td>
				<td>
					<div class="actions-container justify-content-center">
						<a asp-action="Edit" asp-route-id="@juego.id" class="btn-action btn-edit" title="Editar">
							<i class="fas fa-edit"></i>
						</a>
						<a asp-action="Details" asp-route-id="@juego.id" class="btn-action btn-details" title="Detalles">
							<i class="fas fa-eye"></i>
						</a>
						<a asp-action="Delete" asp-route-id="@juego.id" class="btn-action btn-delete" title="Eliminar">
							<i class="fas fa-trash"></i>
						</a>
					</div>
				</td>
			</tr>
		}
	</tbody>
	</table>
