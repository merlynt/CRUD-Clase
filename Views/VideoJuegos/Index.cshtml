@model IEnumerable<appWeb2.Models.VideoJuego>

@{
    ViewData["Title"] = "Lista de Videojuegos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        .table-custom {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            border-radius: 10px;
            overflow: hidden;
            background: white;
        }

            .table-custom thead {
                background-color: #1e3c72;
                color: white;
            }

            .table-custom th {
                padding: 15px;
                font-weight: 600;
                text-transform: uppercase;
                font-size: 0.85rem;
                border: none;
            }

            .table-custom td {
                padding: 12px 15px;
                vertical-align: middle;
                border-bottom: 1px solid #edf2f7;
                color: #4a5568;
            }

            .table-custom tbody tr:hover {
                background-color: #f8fafc;
            }

        .btn-action {
            width: 35px;
            height: 35px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: all 0.2s;
            color: white;
            text-decoration: none;
            border: none;
        }

        .btn-edit {
            background-color: #3b82f6;
        }

        .btn-details {
            background-color: #64748b;
        }

        .btn-delete {
            background-color: #ef4444;
        }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            color: white;
            opacity: 0.9;
        }

        .game-img {
            border-radius: 8px;
            object-fit: cover;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .actions-container {
            display: flex;
            gap: 8px;
        }
    </style>
}

<div class="welcome-box">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Catálogo de Videojuegos</h2>
            <p class="text-muted">Gestiona los títulos disponibles en el sistema</p>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4 shadow-sm" style="background: #1e3c72; border-radius: 10px;">
            <i class="fas fa-plus me-2"></i> Nuevo Juego
        </a>
    </div>

    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Imagen</th>
                    <th>Lanzamiento</th>
                    <th>Descuento</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var juego in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@juego.titulo</div>
                            <small class="text-muted d-block" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @juego.descripcion
                            </small>
                        </td>
                        <td><span class="badge bg-light text-dark border">@juego.categoria</span></td>
                        <td class="fw-bold text-primary">$@juego.precio</td>
                        <td>
                            <img src="@juego.imagen" width="80" height="50" class="game-img" alt="poster" />
                        </td>
                        <td>@juego.fechaLanzamiento.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (juego.porcentajeDescuento > 0)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-arrow-down me-1"></i>@juego.porcentajeDescuento%
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">PVP</span>
                            }
                        </td>
                        <td>
                            <div class="actions-container justify-content-center">
                                <a asp-action="Edit" asp-route-id="@juego.id" class="btn-action btn-edit" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@juego.id" class="btn-action btn-details" title="Detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@juego.id" class="btn-action btn-delete" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>