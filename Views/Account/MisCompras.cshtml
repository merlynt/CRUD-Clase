@model IEnumerable<appWeb2.Models.DetalleCompra>
@{
    ViewData["Title"] = "Mis Compras";
    Layout = "~/Views/Shared/_Layout1.cshtml";
}

<style>
    :root {
        --bg-card: #0f172a; 
        --accent-yellow: #ffc107; 
        --accent-blue: #38bdf8; 
        --text-main: #f8fafc; 
        --text-muted: #94a3b8; 
        --success-green: #22c55e;
    }

    .library-section {
        background-color: var(--bg-body);
        color: var(--text-main);
        min-height: 100vh;
    }

    .gaming-card {
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .gaming-card:hover {
            border-color: var(--accent-blue);
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.15);
            transform: translateY(-4px);
        }

    .game-img-container {
        position: relative;
        overflow: hidden;
    }

    .game-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
        transition: opacity 0.3s ease;
    }

    .gaming-card:hover .game-img {
        opacity: 1;
    }

    .age-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(15, 23, 42, 0.9);
        backdrop-filter: blur(4px);
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: bold;
        border: 1px solid var(--accent-blue);
        color: var(--accent-blue);
    }

    .status-pill {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 4px 10px;
        letter-spacing: 0.5px;
    }

    .price-text {
        color: var(--success-green);
        font-family: 'Segoe UI', Roboto, sans-serif;
        font-weight: 800;
        text-shadow: 0 0 10px rgba(34, 197, 94, 0.2);
    }

    .label-muted {
        color: var(--text-muted);
        font-size: 0.7rem;
        text-transform: uppercase;
        font-weight: 600;
    }

    .divider-custom {
        height: 1px;
        background: linear-gradient(to right, rgba(255,255,255,0.1), transparent);
        margin: 15px 0;
    }

    .btn-action {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        transition: 0.2s;
    }

        .btn-action:hover {
            background: var(--accent-blue);
            color: #000;
            border-color: var(--accent-blue);
        }

    .stat-box {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(56, 189, 248, 0.2);
        border-radius: 10px;
        padding: 15px;
    }

    .form-control-gaming {
        background: rgba(15, 23, 42, 0.7) !important;
        border: 1px solid rgba(56, 189, 248, 0.3) !important;
        color: white !important;
        font-size: 0.9rem;
    }

        .form-control-gaming:focus {
            border-color: var(--accent-blue) !important;
            box-shadow: 0 0 10px rgba(56, 189, 248, 0.2);
        }
    /* Estilo personalizado para el botón PDF */
    .btn-pdf-gaming {
        background: rgba(220, 53, 69, 0.1); /* Fondo rojo muy transparente */
        color: #ff6b6b; /* Texto rojo brillante */
        border: 1px solid rgba(220, 53, 69, 0.4);
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.85rem;
        border-radius: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-pdf-gaming:hover {
            background: #dc3545;
            color: #ffffff;
            border-color: #dc3545;
            box-shadow: 0 0 15px rgba(220, 53, 69, 0.5);
            transform: translateY(-2px);
        }
    
    .btn-gamestore {
        background-color: var(--accent-yellow);
        color: #0f172a; 
        font-weight: 800;
        text-transform: uppercase;
        border-radius: 8px;
        border: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-gamestore:hover {
            background-color: #e0a800;
            color: #0f172a;
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(255, 193, 7, 0.5);
        }
    
</style>
<div class="library-section py-5">
    <div class="container">
        <div class="row mb-5 align-items-center">
            <div class="col-md-4">
                <h2 class="fw-bold text-white mb-1">Mi Biblioteca</h2>
                <p class="text-muted small">Colección de @Model.Count() títulos</p>
            </div>
            <div class="col-md-8">
                <div class="row g-3">
                    <div class="col-4">
                        <div class="stat-box text-center">
                            <div class="label-muted" style="font-size: 0.6rem;">Juegos</div>
                            <div class="fw-bold text-white">@ViewBag.TotalJuegos</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-box text-center">
                            <div class="label-muted" style="font-size: 0.6rem;">Total Gastado</div>
                            <div class="fw-bold text-success">$@ViewBag.TotalGastado.ToString("N2")</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-box text-center">
                            <div class="label-muted" style="font-size: 0.6rem;">Gasto Mes</div>
                            <div class="fw-bold" style="color: var(--accent-blue)">$@ViewBag.GastadoMes.ToString("N2")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-5 p-4 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
            <form method="get" action="@Url.Action("MisCompras")" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="label-muted mb-2">Buscar Videojuego</label>
                    <input type="text" name="buscar" value="@Context.Request.Query["buscar"]"
                           class="form-control form-control-gaming" placeholder="Nombre del juego...">
                </div>
                <div class="col-md-3 col-6">
                    <label class="label-muted mb-2">Desde</label>
                    <input type="date" name="desde" value="@Context.Request.Query["desde"]"
                           class="form-control form-control-gaming">
                </div>
                <div class="col-md-3 col-6">
                    <label class="label-muted mb-2">Hasta</label>
                    <input type="date" name="hasta" value="@Context.Request.Query["hasta"]"
                           class="form-control form-control-gaming">
                </div>
                <div class="col-md-2 d-flex flex-column gap-2 justify-content-end">
                    
                    <button type="submit" class="btn btn-gamestore w-100 py-2 shadow-sm" style="font-size: 0.85rem;">
                        <i class="fa-solid fa-filter me-1"></i> Filtrar
                    </button>

                    
                    <a href="@Url.Action("ExportarPDFMisCompras", new { buscar = Context.Request.Query["buscar"], desde = Context.Request.Query["desde"], hasta = Context.Request.Query["hasta"] })"
                       class="btn btn-pdf-gaming w-100 py-2 shadow-sm">
                        <i class="fa-solid fa-file-pdf me-1"></i> Exportar PDF
                    </a>
                </div>
            </form>
        </div>

        <div class="row g-4">
            @foreach (var detalle in Model)
            {
                <div class="col-xl-6">
                    <div class="card gaming-card d-flex flex-row h-100">
                        <div class="col-4 col-sm-5 game-img-container">
                            <span class="age-badge">@detalle.VideoJuego.clasificacionEdad</span>
                            <img src="@detalle.VideoJuego.imagen" class="game-img" alt="Portada">
                        </div>

                        <div class="col-8 col-sm-7 p-4 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="text-white fw-bold m-0 text-truncate">@detalle.VideoJuego.titulo</h4>
                                @{
                                    var statusClass = detalle.estadoCompra.Contains("COMPLET") ? "bg-success" : "bg-warning text-dark";
                                }
                                <span class="badge status-pill @statusClass">@detalle.estadoCompra</span>
                            </div>

                            <div class="d-flex align-items-center gap-3 mb-3">
                                <span class="text-muted small">
                                    <i class="fa-solid fa-folder-open me-1 text-info"></i> @detalle.VideoJuego.categoria
                                </span>
                                <span class="text-muted small">
                                    <i class="fa-regular fa-calendar me-1"></i> @detalle.fechaHoraTransaccion.ToString("dd/MM/yyyy")
                                </span>
                            </div>

                            <div class="row g-2 mb-2">
                                <div class="col-7">
                                    <div class="label-muted">Código Orden</div>
                                    <div class="text-white small font-monospace">#@detalle.codigoTransaccion.Substring(0, Math.Min(12, detalle.codigoTransaccion.Length))...</div>
                                </div>
                                <div class="col-5">
                                    <div class="label-muted text-end">Cantidad</div>
                                    <div class="text-white fw-bold text-end">@detalle.cantidad u.</div>
                                </div>
                            </div>

                            <div class="divider-custom mt-auto"></div>

                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <div class="label-muted">Total</div>
                                    <span class="fs-3 price-text">$@detalle.total.ToString("N2")</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-action btn-sm" title="Factura">
                                        <i class="fa-solid fa-file-pdf"></i>
                                    </button>
                                    <button class="btn btn-primary btn-sm px-3 fw-bold shadow-sm">
                                        <i class="fa-solid fa-download me-1"></i> Instalar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>