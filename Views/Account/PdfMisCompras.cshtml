@model IEnumerable<appWeb2.Models.DetalleCompra>
@{
    Layout = null;
    // Lógica para mostrar el rango de fechas filtrado en el encabezado
    string fechaInfo = "Todos los registros";
    if (ViewBag.Desde != null || ViewBag.Hasta != null)
    {
        fechaInfo = $"Desde: {ViewBag.Desde?.ToString("dd/MM/yyyy")} - Hasta: {ViewBag.Hasta?.ToString("dd/MM/yyyy")}";
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 11px;
            color: #333;
        }

        .header-container {
            border-bottom: 3px solid #002b45;
            margin-bottom: 20px;
            padding-bottom: 10px;
        }

        /* Estilo del Logo tipo GameStore */
        .brand-box {
            font-family: 'Arial Black', sans-serif;
            font-size: 24px;
            font-weight: bold;
            color: #FFC107; /* Amarillo GameStore */
            background-color: #002b45; /* Azul GameStore */
            display: inline-block;
            padding: 5px 15px;
            border-radius: 5px;
            text-transform: uppercase;
        }

        .report-title {
            color: #002b45;
            font-weight: bold;
            text-transform: uppercase;
            margin: 0;
            font-size: 18px;
        }

        .table thead {
            background-color: #002b45;
            color: white;
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(0, 43, 69, 0.05);
        }

        .total-section {
            margin-top: 20px;
            border-top: 2px solid #eee;
            padding-top: 10px;
        }
    </style>
</head>
<body>

    <div class="header-container">
        <table style="width: 100%; border: none;">
            <tr>
                <td style="width: 50%; border: none;">
                    <div class="brand-box">GAMESTORE</div>
                    <div style="margin-top: 10px;">
                        <strong>Cliente:</strong> @ViewBag.NombreUsuario <br />
                        <strong>Estado de Cuenta:</strong> Historial de Adquisiciones
                    </div>
                </td>
                <td style="width: 50%; border: none; text-align: right; vertical-align: top;">
                    <h2 class="report-title">Reporte de Compras</h2>
                    <p style="margin: 5px 0; font-size: 12px; color: #666;">@fechaInfo</p>
                    <small class="text-muted">Generado el: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
                </td>
            </tr>
        </table>
    </div>

    <table class="table table-striped table-bordered table-sm">
        <thead>
            <tr>
                <th>Fecha de Compra</th>
                <th>Videojuego</th>
                <th>Categoría</th>
                <th class="text-center">Cant.</th>
                <th class="text-end">Precio Unit.</th>
                <th class="text-end">Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.fechaHoraTransaccion.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="fw-bold">@item.VideoJuego.titulo</td>
                    <td>@item.VideoJuego.categoria</td>
                    <td class="text-center">@item.cantidad</td>
                    <td class="text-end">$@((item.total / item.cantidad).ToString("N2"))</td>
                    <td class="text-end fw-bold">$@item.total.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="row total-section">
        <div class="col-7">
            <p class="small text-muted">
                * Este documento detalla las licencias digitales adquiridas por el usuario en la plataforma GameStore.
            </p>
        </div>
        <div class="col-5">
            <table class="table table-sm table-bordered">
                <tr>
                    <th class="bg-light text-end">Juegos Totales:</th>
                    <td class="text-end">@Model.Sum(x => x.cantidad)</td>
                </tr>
                <tr>
                    <th class="bg-light text-end">Inversión Total:</th>
                    <td class="text-end fw-bold" style="font-size: 1.1rem; color: #002b45;">
                        $@Model.Sum(x => x.total).ToString("N2")
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <div style="position: fixed; bottom: 0; width: 100%; text-align: center; font-size: 9px; color: #999;">
        GameStore - Reporte oficial de cliente. Página 1 de 1
    </div>

</body>
</html>