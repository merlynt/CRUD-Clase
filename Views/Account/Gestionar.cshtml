@model appWeb2.Models.GestionCuentaViewModel

@{
    ViewData["Title"] = "Mi Cuenta";
    Layout = "~/Views/Shared/_Layout1.cshtml";
}

<style>
    body {
        
        min-height: 100vh;
    }

    .card-gamestore {
        background: rgba(0, 43, 69, 0.8);
        backdrop-filter: blur(10px);
        border: 2px solid #ffc107; 
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .form-control-gaming {
        background-color: rgba(255, 255, 255, 0.1) !important;
        border: 1px solid rgba(255, 193, 7, 0.3) !important;
        color: white !important;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

        .form-control-gaming:focus {
            border-color: #ffc107 !important;
            box-shadow: 0 0 10px rgba(255, 193, 7, 0.4);
            background-color: rgba(255, 255, 255, 0.15) !important;
        }

    .input-group-text-gaming {
        background-color: #ffc107 !important;
        color: #002b45 !important;
        border: none;
        border-radius: 10px 0 0 10px !important;
    }

    .btn-gamestore {
        background-color: #ffc107;
        color: #002b45;
        font-weight: 800;
        text-transform: uppercase;
        border-radius: 12px;
        border: none;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .btn-gamestore:hover {
            background-color: #e0a800;
            transform: scale(1.02);
            box-shadow: 0 0 20px rgba(255, 193, 7, 0.5);
        }

    .section-title {
        border-left: 4px solid #ffc107;
        padding-left: 10px;
        color: #ffc107;
        font-weight: bold;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <div class="card card-gamestore p-4">
                <div class="text-center mb-4">
                    <h2 class="fw-black text-warning">
                        <i class="fa-solid fa-circle-user mb-2 d-block" style="font-size: 3rem;"></i>
                        MI PERFIL
                    </h2>
                    <p class="text-light opacity-75">Configura tu identidad en GameStore</p>
                </div>

                @if (ViewBag.MensajeExito != null)
                {
                    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center">
                        <i class="fa-solid fa-circle-check me-2 fs-4"></i>
                        <div>@ViewBag.MensajeExito</div>
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center">
                        <i class="fa-solid fa-circle-exclamation me-2 fs-4"></i>
                        <div>@ViewBag.Error</div>
                    </div>
                }

                <form asp-action="Gestionar" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <h5 class="section-title mb-3">DATOS PERSONALES</h5>
                    <div class="mb-4">
                        <label asp-for="Nombre" class="form-label text-light small fw-bold">NOMBRE DE AVATAR</label>
                        <div class="input-group">
                            <span class="input-group-text input-group-text-gaming">
                                <i class="fa-solid fa-id-badge"></i>
                            </span>
                            <input asp-for="Nombre" class="form-control form-control-gaming" placeholder="Tu nombre público" required />
                        </div>
                        <span asp-validation-for="Nombre" class="text-info small"></span>
                    </div>

                    <div class="py-2">
                        <h5 class="section-title mb-3">SEGURIDAD</h5>
                        <div class="bg-dark bg-opacity-25 p-3 rounded-3 mb-4">
                            <p class="small text-warning mb-3">
                                <i class="fa-solid fa-shield-halved me-1"></i> Completa solo si deseas cambiar tu contraseña.
                            </p>

                            <div class="mb-3">
                                <label asp-for="PasswordActual" class="form-label text-light small">Contraseña Actual</label>
                                <div class="input-group">
                                    <span class="input-group-text input-group-text-gaming bg-opacity-75">
                                        <i class="fa-solid fa-lock-open"></i>
                                    </span>
                                    <input asp-for="PasswordActual" type="password" class="form-control form-control-gaming" placeholder="Clave actual" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="NuevaPassword" class="form-label text-light small">Nueva Contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text input-group-text-gaming">
                                        <i class="fa-solid fa-key"></i>
                                    </span>
                                    <input asp-for="NuevaPassword" type="password" class="form-control form-control-gaming" placeholder="Mínimo 6 caracteres" />
                                </div>
                            </div>

                            <div class="mb-0">
                                <label asp-for="ConfirmarPassword" class="form-label text-light small">Confirmar Nueva Contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text input-group-text-gaming">
                                        <i class="fa-solid fa-check-double"></i>
                                    </span>
                                    <input asp-for="ConfirmarPassword" type="password" class="form-control form-control-gaming" placeholder="Repite la clave" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-gamestore w-100 py-3 shadow mt-2">
                        <i class="fa-solid fa-rocket me-2"></i> ACTUALIZAR CUENTA
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}