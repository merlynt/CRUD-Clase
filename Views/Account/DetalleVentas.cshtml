@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuario = Context.Session.GetString("usuario");
}
@model List<VentasViewModel>

<body>
        <div class="content-card">
            <div class="row align-items-center">
                <div class="col-md-5">
                    <h4 class="mb-1">Historial de Ventas</h4>
                    <p class="text-muted small mb-0">Visualiza y filtra los registros de transacciones.</p>
                </div>
                <div class="col-md-7">
                    <form method="get" class="filter-section justify-content-md-end">
                        <div class="text-start">
                            <label class="small fw-bold text-muted d-block">Fecha Inicio</label>
                            <input type="date" name="desde" class="form-control form-control-sm"
                                   value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" style="width: 160px;" />
                        </div>
                        <div class="text-start">
                            <label class="small fw-bold text-muted d-block">Fecha Fin</label>
                            <input type="date" name="hasta" class="form-control form-control-sm"
                                   value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" style="width: 160px;" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm px-4 shadow-sm"
                                style="background: #1e3c72; border: none; height: 31px;">
                            Filtrar
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="content-card">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Videojuego</th>
                            <th class="text-center">Cant.</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Código</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.NombreUsuario</td>
                                <td>@item.NombreVideoJuego</td>
                                <td class="text-center">@item.cantidad</td>
                                <td class="text-success fw-bold">$@item.total</td>
                                <td><span class="status-badge">@item.estadoCompra</span></td>
                                <td class="text-muted small">@item.fechaHoraTransaccion</td>
                                <td><code style="color: #2a5298;">@item.codigoTransaccion</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                    {
                        <li class="page-item @(ViewBag.PaginaActual == i ? "active" : "")">
                            <a class="page-link shadow-sm" href="?pagina=@i&desde=@ViewBag.Desde&hasta=@ViewBag.Hasta">@i</a>
                        </li>
                    }
                </ul>
            </nav>

    </>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>