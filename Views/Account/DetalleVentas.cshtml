@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuario = Context.Session.GetString("usuario");
}
@model List<VentasViewModel>

<body>
    <div class="content-card">
        <div class="row align-items-center">
            <div class="col-md-3">
                <h4 class="mb-1">Historial de Ventas</h4>
                <p class="text-muted small mb-0">Visualiza y filtra los registros.</p>
            </div>
            <div class="col-md-9">
                <form method="get" class="filter-section d-flex flex-wrap justify-content-md-end gap-2 align-items-end">

                    <div class="text-start">
                        <label class="small fw-bold text-muted d-block">Cliente</label>
                        <input type="text" name="cliente" class="form-control form-control-sm"
                               value="@ViewBag.Cliente" style="width: 140px;" placeholder="Nombre..." />
                    </div>

                    <div class="text-start">
                        <label class="small fw-bold text-muted d-block">Videojuego</label>
                        <input type="text" name="videojuego" class="form-control form-control-sm"
                               value="@ViewBag.Videojuego" style="width: 140px;" placeholder="Juego..." />
                    </div>

                    <div class="text-start">
                        <label class="small fw-bold text-muted d-block">Desde</label>
                        <input type="date" name="desde" class="form-control form-control-sm"
                               value="@ViewBag.Desde?.ToString("yyyy-MM-dd")" style="width: 130px;" />
                    </div>

                    <div class="text-start">
                        <label class="small fw-bold text-muted d-block">Hasta</label>
                        <input type="date" name="hasta" class="form-control form-control-sm"
                               value="@ViewBag.Hasta?.ToString("yyyy-MM-dd")" style="width: 130px;" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm px-4 shadow-sm"
                                style="background: #1e3c72; border: none; height: 31px;">
                            Filtrar
                        </button>
                        <a href="@Url.Action("ExportarPDF", "Account", new { 
                               desde = Context.Request.Query["desde"].ToString(), 
                               hasta = Context.Request.Query["hasta"].ToString() 
                           })"
                           class="btn btn-danger btn-sm px-4 shadow-sm"
                           style="height: 31px; display: flex; align-items: center;"
                           target="_blank">
                            Exportar PDF
                        </a>
                        
                    </div>

                </form>
            </div>
        </div>
    </div>

    <div class="content-card mt-3">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Videojuego</th>
                        <th class="text-center">Cant.</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Fecha</th>
                        <th>Código</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.NombreUsuario</td>
                            <td>@item.NombreVideoJuego</td>
                            <td class="text-center">@item.cantidad</td>
                            <td class="text-success fw-bold">$@item.total</td>
                            <td><span class="status-badge">@item.estadoCompra</span></td>
                            <td class="text-muted small">@item.fechaHoraTransaccion</td>
                            <td><code style="color: #2a5298;">@item.codigoTransaccion</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                {
                    <li class="page-item @(ViewBag.PaginaActual == i ? "active" : "")">
                        <a class="page-link shadow-sm"
                           href="?pagina=@i&desde=@ViewBag.Desde&hasta=@ViewBag.Hasta&cliente=@ViewBag.Cliente&videojuego=@ViewBag.Videojuego">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>