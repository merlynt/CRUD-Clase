@using System.Text.Json
@using appWeb2.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuarioJson = Context.Session.GetString("usuario");
    Usuario usuarioLogueado = null;

    if (!string.IsNullOrEmpty(usuarioJson))
    {
        var opciones = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        usuarioLogueado = JsonSerializer.Deserialize<Usuario>(usuarioJson, opciones);

    }
}

<body>

    <div class="welcome-box">
        <h4>Bienvenido, @usuarioLogueado.nombre👋</h4>
            <p class="text-muted mb-0">
                Este es tu panel principal. Aquí podrás visualizar estadísticas y gestionar el sistema.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <select id="filtroCategoria" class="form-select" asp-items="@ViewBag.CategoriasSelect">
                    <option value="" selected>Seleccionar todos</option>
                </select>
                @* Grafica de juegos por categoria *@
                <div id="container"></div>
            </div>
            <div class="col-md-6"> 
                <div id="containerPastel" style="height: 450px; padding: 10px;"></div>
            </div>
            <div class="col-md-6 mt-4">
                <div class="welcome-box">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <label for="fechaFiltro" class="fw-bold">Seleccionar Periodo:</label>
                            <input type="month" id="fechaFiltro" class="form-control" style="width: 200px;"
                                   value="2026-04">
                        </div>
                    </div>
                    <div id="containerUsuarios" style="height: 400px;"></div>
                </div>
            </div>
            <div class="col-md-6 mt-4">
                <div class="welcome-box shadow-sm">
                    <div id="containerIngresos" style="height: 400px; width: 100%;"></div>
                </div>
            </div>
        </div>
            
    <script>
        function cargarGrafica(id = "") {
            $.get('/Account/ObtenerDatos', { id: id }, function(data) {

                var categorias = data.map(x => x.categoria);
                var totales = data.map(x => x.total);

                Highcharts.chart('container', {
                    chart: { type: 'column' },
                    title: { text: 'Grafica de video juegos por categorias de zona digital' },
                    xAxis: { categories: categorias }, 
                    series: [{
                        name: 'Juegos',
                        data: totales
                    }]
                });
            });
        }
        cargarGrafica();

        $('#filtroCategoria').change(function() {
            cargarGrafica($(this).val());
        });

          function cargarGraficaPastel() {
             $.get('/Account/ObtenerVentasPastel', function(data) {

                 Highcharts.chart('containerPastel', {
                     chart: {
                         type: 'pie'
                     },
                     title: {
                         text: 'Distribución de Ventas por Videojuego'
                     },
                     tooltip: {
                         pointFormat: '{series.name}: <b>{point.y} unidades</b>'
                     },
                     plotOptions: {
                         pie: {
                             allowPointSelect: true,
                             cursor: 'pointer',
                             dataLabels: [{
                                 enabled: true,
                                 distance: 20,
                                 format: '{point.name}' 
                             }, {
                                 enabled: true,
                                 distance: -40,
                                 format: '{point.percentage:.1f}%', 
                                 style: {
                                     fontSize: '1.2em',
                                     textOutline: 'none',
                                     opacity: 0.7
                                 },
                                 filter: {
                                     operator: '>',
                                     property: 'percentage',
                                     value: 10
                                 }
                             }]
                         }
                     },
                     series: [{
                         name: 'Ventas',
                         colorByPoint: true,
                         data: data 
                     }]
                 });
             });
         }

         $(document).ready(function() {
             cargarGraficaPastel();
         });

        function cargarGraficaUsuarios(verTodo = false) {
           
            if(verTodo) $('#fechaFiltro').val('');

            var periodoSeleccionado = $('#fechaFiltro').val();

            $.get('/Account/ObtenerRegistroUsuarios', { periodo: periodoSeleccionado }, function(data) {
                var etiquetas = data.map(x => x.etiqueta);
                var totales = data.map(x => x.total);

                Highcharts.chart('containerUsuarios', {
                    chart: { type: 'area' },
                    title: {
                         text: 'Usuarios registrados'
                    },
                    title: { text: periodoSeleccionado ? 'Detalle Diario de: ' + periodoSeleccionado : 'Crecimiento Anual 2026' },
                    xAxis: { categories: etiquetas },
                    yAxis: { title: { text: 'Nuevos Usuarios' }, allowDecimals: false },
                    series: [{
                        name: 'Registros',
                        data: totales,
                        color: '#3498db',
                        fillOpacity: 0.3
                    }]
                });
            });
        }

      
        $('#fechaFiltro').on('change', function() {
            cargarGraficaUsuarios();
        });

        $(document).ready(function() {
            cargarGraficaUsuarios();
        });
                 function cargarGraficaIngresos() {
             $.get('/Account/ObtenerIngresosPorCategoria', function(data) {
                 var nombresCategorias = data.map(x => x.name);
                 var valoresMonetarios = data.map(x => x.y);

                 Highcharts.chart('containerIngresos', {
                     chart: {
                         type: 'column'
                     },
                     title: {
                         text: 'Ingresos Totales por Categoría de Videojuegos'
                     },
                     xAxis: {
                         categories: nombresCategorias,
                         title: { text: 'Categorías (Tabla Externa)' }
                     },
                     yAxis: {
                         min: 0,
                         title: { text: 'Total Recaudado (USD)' },
                         labels: {
                             format: '${value}'
                         }
                     },
                     tooltip: {
                         valuePrefix: '$',
                         pointFormat: 'Ingresos: <b>${point.y:,.2f}</b>'
                     },
                     series: [{
                         name: 'Ventas en $',
                         data: valoresMonetarios,
                         color: '#27ae60', 
                         dataLabels: {
                             enabled: true,
                             format: '${point.y:,.2f}'
                         }
                     }],
                     credits: { enabled: false }
                 });
             });
         }

         $(document).ready(function() {
             cargarGraficaIngresos();
         });

    </script>
