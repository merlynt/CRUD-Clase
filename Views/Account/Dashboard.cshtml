        function cargarGraficaUsuarios(verTodo = false) {
           
            if(verTodo) $('#fechaFiltro').val('');

            var periodoSeleccionado = $('#fechaFiltro').val();

            $.get('/Account/ObtenerRegistroUsuarios', { periodo: periodoSeleccionado }, function(data) {
                var etiquetas = data.map(x => x.etiqueta);
                var totales = data.map(x => x.total);

                Highcharts.chart('containerUsuarios', {
                    chart: { type: 'area' },
                    title: { text: periodoSeleccionado ? 'Detalle Diario de: ' + periodoSeleccionado : 'Crecimiento Anual 2026' },
                    xAxis: { categories: etiquetas },
                    yAxis: { title: { text: 'Nuevos Usuarios' }, allowDecimals: false },
                    series: [{
                        name: 'Registros',
                        data: totales,
                        color: '#3498db',
                        fillOpacity: 0.3
                    }]
                });
            });
        }

      
        $('#fechaFiltro').on('change', function() {
            cargarGraficaUsuarios();
        });

        $(document).ready(function() {
            cargarGraficaUsuarios();
        });
