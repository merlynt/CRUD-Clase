
@{
    Layout = null;
    var usuario = Context.Session.GetString("usuario");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Dashboard</title>
    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://code.highcharts.com/modules/exporting.js"></script>
    <script src="https://code.highcharts.com/modules/export-data.js"></script>
    <script src="https://code.highcharts.com/modules/accessibility.js"></script>
    <script src="https://code.highcharts.com/themes/adaptive.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.js" integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", sans-serif;
            background: var(--highcharts-background-color);
            color: var(--highcharts-neutral-color-100);
        }

        .highcharts-figure,
        .highcharts-data-table table {
            min-width: 310px;
            max-width: 800px;
            margin: 1em auto;
        }

        #container {
            height: 400px;
        }

        .highcharts-data-table table {
            font-family: Verdana, sans-serif;
            border-collapse: collapse;
            border: 1px solid var(--highcharts-neutral-color-10, #e6e6e6);
            margin: 10px auto;
            text-align: center;
            width: 100%;
            max-width: 500px;
        }

        .highcharts-data-table caption {
            padding: 1em 0;
            font-size: 1.2em;
            color: var(--highcharts-neutral-color-60, #666);
        }

        .highcharts-data-table th {
            font-weight: 600;
            padding: 0.5em;
        }

        .highcharts-data-table td,
        .highcharts-data-table th,
        .highcharts-data-table caption {
            padding: 0.5em;
        }

        .highcharts-data-table thead tr,
        .highcharts-data-table tbody tr:nth-child(even) {
            background: var(--highcharts-neutral-color-3, #f7f7f7);
        }

        .highcharts-description {
            margin: 0.3rem 10px;
        }


        body {
            background-color: #f5f7fb;
        }

        .navbar-custom {
            background: linear-gradient(90deg, #1e3c72, #2a5298);
        }

        .navbar-brand {
            font-weight: bold;
            color: white !important;
        }

        .user-info {
            color: white;
            font-weight: 500;
        }

        .btn-logout {
            border-radius: 10px;
        }

        .dashboard-container {
            padding: 30px;
        }

        .card-placeholder {
            height: 250px;
            border-radius: 15px;
            border: 2px dashed #ccc;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
            font-weight: 500;
            background: white;
        }

        .welcome-box {
            background: white;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>


    <nav class="navbar navbar-expand-lg navbar-custom px-4">
        <a class="navbar-brand" href="#">Administración de sistema</a>

        <div class="ms-auto d-flex align-items-center gap-3">
            <span class="user-info">
                👤 @usuario
            </span>

            <a asp-controller="Account" asp-action="Logout" class="btn btn-light btn-sm btn-logout">
                Cerrar Sesión
            </a>
        </div>
    </nav>
    <div class="dashboard-container">


        <div class="welcome-box">
            <h4>Bienvenido, @usuario 👋</h4>
            <p class="text-muted mb-0">
                Este es tu panel principal. Aquí podrás visualizar estadísticas y gestionar el sistema.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <select id="filtroCategoria" class="form-select" asp-items="@ViewBag.CategoriasSelect">
                    <option value="" selected>Seleccionar todos</option>
                </select>
                @* Grafica de juegos por categoria *@
                <div id="container"></div>
            </div>
            <div class="col-md-6"> 
                <div id="containerPastel" style="height: 400px; margin-top: 40px;"></div>
            </div>
            <div class="col-md-6 mt-4">
                <div class="welcome-box">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4>Análisis de Registros</h4>
                        <div class="d-flex align-items-center gap-2">
                            <label for="fechaFiltro" class="fw-bold">Seleccionar Periodo:</label>
                            <input type="month" id="fechaFiltro" class="form-control" style="width: 200px;"
                                   value="2026-04">
                            <button class="btn btn-primary" onclick="cargarGraficaUsuarios()">Ver Todo el Año</button>
                        </div>
                    </div>
                    <div id="containerUsuarios" style="height: 400px;"></div>
                </div>
            </div>
            <div class="col-md-6 mt-4">
                <div class="welcome-box shadow-sm">
                    <div id="containerIngresos" style="height: 400px; width: 100%;"></div>
                </div>
            </div>
        </div>
             
        
    </div>
    <script>
        function cargarGrafica(id = "") {
            $.get('/Account/ObtenerDatos', { id: id }, function(data) {

                var categorias = data.map(x => x.categoria);
                var totales = data.map(x => x.total);

                Highcharts.chart('container', {
                    chart: { type: 'column' },
                    title: { text: 'Grafica de video juegos por categorias de zona digital' },
                    xAxis: { categories: categorias }, 
                    series: [{
                        name: 'Juegos',
                        data: totales
                    }]
                });
            });
        }
        cargarGrafica();

        $('#filtroCategoria').change(function() {
            cargarGrafica($(this).val());
        });

